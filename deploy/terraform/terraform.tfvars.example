# Hetzner Cloud API token
hcloud_token = "your-hetzner-api-token"

# SSH public key - can be:
# 1. Path to local .pub file: "~/.ssh/id_ed25519.pub"
# 2. Full key string: "ssh-ed25519 AAAAC3... user@host"
ssh_public_key = "~/.ssh/id_ed25519.pub"

# OR use existing SSH key from Hetzner (leave empty to create new)
# use_existing_ssh_key = "my-existing-key-name"

# Server configuration
server_name = "phuong-control-plane"
server_type = "cx22"
location = "nbg1"
